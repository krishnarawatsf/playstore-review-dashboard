# N8N API Configuration
# Get these values from your N8N instance

# API Base URL for N8N (e.g., http://localhost:5678 for local, https://n8n.example.com for production)
VITE_API_BASE_URL=http://localhost:5678

# N8N Webhook paths for specific workflows
# Example: /webhook/reviews-v1
VITE_N8N_REVIEWS_WEBHOOK=/webhook/reviews

# Export report webhook path
# Example: /webhook/export-v1
VITE_N8N_EXPORT_WEBHOOK=/webhook/export

# Enable debug mode (true/false)
VITE_DEBUG_MODE=false

# Application environment
VITE_APP_ENV=development
