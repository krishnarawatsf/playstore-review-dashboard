# Production Environment Variables for Vercel
# These will be set through Vercel Environment Variables UI

# API base URL - use your production N8N instance
VITE_API_BASE_URL=https://n8n.example.com

# N8N webhook paths
VITE_N8N_REVIEWS_WEBHOOK=/webhook/reviews
VITE_N8N_EXPORT_WEBHOOK=/webhook/export

# Environment marker
VITE_APP_ENV=production
VITE_DEBUG_MODE=false
